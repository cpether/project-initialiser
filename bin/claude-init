#!/usr/bin/env node
const fs = require('fs');
const path = require('path');
const { spawnSync } = require('child_process');

const libDir = path.resolve(__dirname, '..', 'lib');
const manifest = require(path.join(libDir, 'manifest'));
const userManifest = require(path.join(libDir, 'user-manifest'));
const discover = require(path.join(libDir, 'discover'));
const projectState = require(path.join(libDir, 'project-state'));
const picker = require(path.join(libDir, 'picker'));
const wizard = require(path.join(libDir, 'wizard'));
const mcpAdd = require(path.join(libDir, 'mcp-add'));
const mcpWrap = require(path.join(libDir, 'mcp-wrap'));
const scopeMove = require(path.join(libDir, 'scope-move'));
const migrate = require(path.join(libDir, 'migrate'));
const secretsResolve = require(path.join(libDir, 'secrets-resolve'));
const backends = {
  keychain: require(path.join(libDir, 'backends', 'keychain')),
  op: require(path.join(libDir, 'backends', 'op')),
};

const SKIP_MARKER = '.claude/.claude-init-skip';

function die(msg, code = 1) {
  process.stderr.write(`claude-init: ${msg}\n`);
  process.exit(code);
}

function bold(s) { return `\x1b[1m${s}\x1b[22m`; }
function dim(s) { return `\x1b[2m${s}\x1b[22m`; }
function green(s) { return `\x1b[32m${s}\x1b[39m`; }
function yellow(s) { return `\x1b[33m${s}\x1b[39m`; }

function parseArgs(argv) {
  const args = { _: [], flags: {} };
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a === '--') { args._.push(...argv.slice(i + 1)); break; }
    if (a.startsWith('--')) {
      const [k, v] = a.slice(2).split('=');
      if (v !== undefined) args.flags[k] = v;
      else if (i + 1 < argv.length && !argv[i + 1].startsWith('--')) { args.flags[k] = argv[++i]; }
      else args.flags[k] = true;
    } else args._.push(a);
  }
  return args;
}

function wantsHelp(args) {
  return args.flags.help || args._.includes('help') || args._.includes('-h') || args._.includes('--help');
}

function findRoot() { return manifest.findRepoRoot(); }
function isGitRepo(root) { return fs.existsSync(path.join(root, '.git')); }
function ctx() { const root = findRoot(); return { root, isGit: isGitRepo(root) }; }

async function cmdInit() {
  return wizard.runInit(ctx());
}

async function cmdCheck() {
  const { root } = ctx();
  const skipMarker = path.join(root, SKIP_MARKER);
  if (fs.existsSync(manifest.manifestPath(root)) || fs.existsSync(skipMarker)) process.exit(0);
  const choice = await picker.select({
    message: `No claude-init setup for ${root}. Configure now?`,
    choices: [
      { name: 'Yes, run the wizard', value: 'init' },
      { name: 'Not now (ask again next time)', value: 'skip' },
      { name: 'Never for this directory', value: 'never' },
    ],
  }).catch(() => 'skip');
  if (choice === 'never') {
    fs.mkdirSync(path.dirname(skipMarker), { recursive: true });
    fs.writeFileSync(skipMarker, '');
    console.log(dim('Skip marker written. Delete .claude/.claude-init-skip to re-enable.'));
    process.exit(0);
  }
  if (choice === 'init') return cmdInit();
  process.exit(0);
}

async function cmdMcp(args) {
  const sub = args._[1];
  if (!sub || wantsHelp(args)) {
    process.stdout.write(mcpHelpText());
    return;
  }
  if (sub === 'add') return mcpAdd.runAdd(ctx());
  if (sub === 'wrap') {
    const name = args._[2];
    if (!name) die('usage: claude-init mcp wrap <name>');
    const result = await mcpWrap.runWrap(ctx(), name);
    if (result.status === 'already-wrapped') {
      console.log(dim(`${name} is already wrapped at ${result.scope} scope`));
    } else if (result.status === 'skipped') {
      console.log(dim(`Skipped ${name}; ${result.skippedSecret} was not configured.`));
    } else {
      console.log(green(`wrapped ${name} at ${result.scope} scope`));
      if (result.argvWarnings && result.argvWarnings.length) {
        console.log(yellow(`warning: argv references remain: ${result.argvWarnings.map((v) => '${' + v + '}').join(', ')}`));
      }
    }
    return;
  }
  if (sub === 'move') return cmdMcpMove(args);
  if (sub === 'remap') return cmdMcpRemap(args);
  if (sub === 'enable' || sub === 'disable') {
    const name = args._[2];
    if (!name) die(`usage: claude-init mcp ${sub} <name>`);
    const { root } = ctx();
    const located = scopeMove.locateEntry(root, name);
    if (located && located.scope === 'project') {
      projectState.setProjectMcpjsonServer(root, name, sub === 'enable');
    } else {
      const known = located || discover.discoverMcps(root).some((m) => m.name === name);
      if (!known) die(`MCP "${name}" not found for ${root}`);
      projectState.setDisabledMcps(root, [name], sub === 'disable' ? [name] : []);
    }
    console.log(green(`mcp ${name}: ${sub}d for this repo`));
    return;
  }
  die('usage: claude-init mcp <add|wrap|move|remap|enable|disable> [args]');
}

async function cmdMcpRemap(args) {
  const { root } = ctx();
  let name = args._[2];
  if (!name) {
    const all = scopeMove.listAllByScope(root);
    if (all.length === 0) die('no MCPs found in any scope');
    const picked = await picker.select({
      message: 'Which MCP to remap?',
      choices: all.map((e) => ({ name: `${e.name}  ${dim('[' + e.scope + ']')}`, value: `${e.scope}|${e.name}` })),
    });
    name = picked.split('|')[1];
  }

  const located = scopeMove.locateEntry(root, name);
  if (!located) die(`MCP "${name}" not found in any scope for ${root}`);
  if (!migrate.isClaudeInitWrapped(located.cfg)) {
    die(`"${name}" is not wrapped via claude-init exec — nothing to remap. Migrate it first via \`claude-init init\`.`);
  }

  const tokens = migrate.readWrappedTokens(located.cfg);
  console.log(bold(`\nCurrent secrets for ${name}:`));
  for (const t of tokens) {
    const arrow = t.envKey === t.secretName ? '' : `${dim(' →')} ${t.secretName}`;
    console.log(`  env ${t.envKey}${arrow}`);
  }

  const envKey = await picker.select({
    message: '\nWhich env key to remap?',
    choices: tokens.map((t) => ({
      name: `${t.envKey}  ${dim('(currently → ' + t.secretName + ')')}`,
      value: t.envKey,
    })),
  });
  const current = tokens.find((t) => t.envKey === envKey);

  const newSecretName = await picker.input({
    message: `New secret name for ${envKey} (currently → ${current.secretName}):`,
    validate: (v) => /^[A-Za-z_][A-Za-z0-9_]*$/.test(v) ? true : 'use letters, digits, underscores',
  });

  // Apply the new mapping to .mcp.json (or wherever it lives)
  const newMappings = tokens.map((t) =>
    t.envKey === envKey ? { envKey, secretName: newSecretName } : t,
  );
  const newCfg = migrate.rewriteWrappedTokens(located.cfg, newMappings);
  scopeMove.writeToScope(root, located.scope, name, newCfg);
  console.log(green(`\nupdated ${name}: ${envKey} → ${newSecretName}`));

  // Check whether the new secret is configured anywhere
  const exists = secretsResolve.resolve(root, newSecretName);
  if (exists) {
    console.log(dim(`secret '${newSecretName}' already configured at ${exists.scope} scope — using existing value.`));
    return;
  }

  console.log(yellow(`\nsecret '${newSecretName}' is not configured yet.`));
  const configNow = await picker.confirm({
    message: `Configure '${newSecretName}' now?`,
    default: true,
  }).catch(() => false);
  if (!configNow) {
    console.log(dim(`run when ready:  claude-init secret set ${newSecretName} [--scope user|project]`));
    return;
  }

  const projData = manifest.read(root) || { version: 1, mcps: [], skills: [], secrets: {} };
  const result = await wizard.configureSecret(newSecretName, root, projData);
  if (result && result.storedAs && result.storedAs !== newSecretName) {
    // configureSecret renamed again — retarget the .mcp.json mapping
    const finalName = result.storedAs;
    const finalMappings = newMappings.map((t) =>
      t.envKey === envKey ? { envKey, secretName: finalName } : t,
    );
    const finalCfg = migrate.rewriteWrappedTokens(located.cfg, finalMappings);
    scopeMove.writeToScope(root, located.scope, name, finalCfg);
    console.log(dim(`adjusted mapping after rename: ${envKey} → ${finalName}`));
  }
  manifest.write(root, projData);
}

const SCOPE_LABELS = {
  user: 'User (~/.claude.json mcpServers — available everywhere)',
  project: 'Project (.mcp.json — committable, shared with team)',
  local: 'Local (~/.claude.json projects[<root>] — this repo only)',
};

async function cmdMcpMove(args) {
  const { root } = ctx();
  let name = args._[2];
  let to = args.flags.to;

  if (!name) {
    const all = scopeMove.listAllByScope(root);
    if (all.length === 0) die('no MCPs in any scope to move');
    const picked = await picker.select({
      message: 'Which MCP to move?',
      choices: all.map((e) => ({
        name: `${e.name}  ${dim('[' + e.scope + ']')}`,
        value: `${e.scope}|${e.name}`,
      })),
    });
    name = picked.split('|')[1];
  }

  const located = scopeMove.locateEntry(root, name);
  if (!located) die(`MCP "${name}" not found in any scope for ${root}`);

  if (!to) {
    const others = ['user', 'project', 'local'].filter((s) => s !== located.scope);
    to = await picker.select({
      message: `Move "${name}" from ${bold(located.scope)} to:`,
      choices: others.map((s) => ({ name: SCOPE_LABELS[s], value: s })),
    });
  }

  // Pre-check target for collisions before calling move()
  const existingAtTarget = scopeMove.entryAtScope(root, to, name);
  if (existingAtTarget) {
    const adjustedSource = scopeMove.adjustWrapperPath(located.cfg, to);
    if (migrate.equivalent(adjustedSource, existingAtTarget)) {
      console.log(dim(`\n"${name}" already exists at ${to} scope with an equivalent definition.`));
      const ok = await picker.confirm({
        message: `Drop the ${located.scope}-scope copy and keep the ${to}-scope one?`,
        default: true,
      });
      if (!ok) { console.log(dim('No changes.')); return; }
      scopeMove.removeFromScope(root, located.scope, name);
      console.log(green(`removed ${located.scope}-scope ${name}; kept the equivalent ${to} version`));
      return;
    }
    die(`${to} scope already has "${name}" with a different definition. Inspect with \`claude-init discover\` and resolve manually.`);
  }

  try {
    const result = scopeMove.move(root, name, to);
    console.log(green(`moved ${name}: ${result.from} → ${result.to}`));
    if (to === 'project' && located.scope !== 'project') {
      const isGit = isGitRepo(root);
      console.log(dim(isGit
        ? '  (committable; teammates need claude-init on PATH if it uses claude-init exec)'
        : '  (not a git repo — committability moot here)'));
    }
  } catch (err) {
    die(err.message);
  }
}

async function cmdPlugin(args) {
  const sub = args._[1];
  const id = args._[2];
  if (!sub || wantsHelp(args)) {
    process.stdout.write(pluginHelpText());
    return;
  }
  if (!sub || !id) die('usage: claude-init plugin <enable|disable|unset> <plugin@marketplace>');
  if (!['enable', 'disable', 'unset'].includes(sub)) die(`unknown plugin action: ${sub}`);
  const { root } = ctx();
  projectState.setPluginState(root, id, sub);
  console.log(green(`plugin ${id}: ${sub}`));
}

async function cmdDiscover() {
  process.stdout.write(JSON.stringify({ mcps: discover.discoverMcps(ctx().root), skills: discover.discoverSkills() }, null, 2) + '\n');
}

async function cmdState() {
  const { root } = ctx();
  process.stdout.write(JSON.stringify(projectState.getProjectState(root), null, 2) + '\n');
}

async function cmdSecret(args) {
  const sub = args._[1];
  const name = args._[2];
  const scope = args.flags.scope || 'project';
  if (!sub || wantsHelp(args)) {
    process.stdout.write(secretHelpText());
    return;
  }
  if (!['user', 'project'].includes(scope)) die(`--scope must be user or project (got: ${scope})`);
  const { root } = ctx();

  if (sub === 'list') {
    const all = secretsResolve.listAll(root);
    if (all.length === 0) { console.log('(no secrets)'); return; }
    for (const s of all) {
      const where = s.overridden ? `${s.effective}, overrides user` : s.effective;
      const ref = s[s.effective];
      const detail = ref.backend === 'keychain'
        ? `keychain (${ref.service}${ref.isolated ? ', isolated' : ''})`
        : `1password (${ref.ref})`;
      console.log(`${s.name}\t[${where}]\t${detail}`);
    }
    return;
  }
  if (!name) die(`usage: claude-init secret ${sub} <NAME> [--scope user|project]`);

  if (sub === 'set') {
    const backend = args.flags.backend || 'keychain';
    if (!backends[backend]) die(`unknown backend: ${backend}`);
    let ref;
    const isolated = !!args.flags.isolate;
    if (backend === 'keychain') {
      const value = args.flags.value && args.flags.value !== true
        ? String(args.flags.value)
        : await picker.password({ message: `Value for ${name}:` });
      if (!value) die('empty value');
      ref = backends.keychain.set({ name, value, isolated, repoHash: manifest.repoHash(root) });
    } else {
      const opRef = args.flags.ref && args.flags.ref !== true
        ? String(args.flags.ref)
        : await picker.input({ message: `op:// reference for ${name}:`, validate: (v) => v.startsWith('op://') || 'must start with op://' });
      ref = backends.op.set({ name, opRef });
    }
    const entry = { ...ref, isolated: isolated || undefined };
    if (scope === 'project') {
      const data = manifest.read(root) || { version: 1, mcps: [], skills: [], secrets: {} };
      data.secrets = data.secrets || {};
      data.secrets[name] = entry;
      manifest.write(root, data);
    } else {
      const data = userManifest.load();
      data.secrets = data.secrets || {};
      data.secrets[name] = entry;
      userManifest.write(data);
    }
    console.log(green(`stored ${name} (${scope}, ${backend}${isolated ? ', isolated' : ''})`));
    return;
  }
  if (sub === 'get') {
    const r = secretsResolve.resolve(root, name);
    if (!r) die(`no secret ${name} (project or user)`);
    process.stdout.write(backends[r.ref.backend].get({ ref: r.ref }));
    return;
  }
  if (sub === 'rm') {
    if (scope === 'project') {
      const data = manifest.read(root);
      if (!data || !data.secrets || !data.secrets[name]) die(`no project secret ${name}`);
      backends[data.secrets[name].backend].rm({ ref: data.secrets[name] });
      delete data.secrets[name];
      manifest.write(root, data);
    } else {
      const data = userManifest.load();
      if (!data.secrets || !data.secrets[name]) die(`no user secret ${name}`);
      backends[data.secrets[name].backend].rm({ ref: data.secrets[name] });
      delete data.secrets[name];
      userManifest.write(data);
    }
    console.log(`removed ${name} (${scope})`);
    return;
  }
  die(`unknown secret subcommand: ${sub}`);
}

async function cmdExec() {
  const dashIdx = process.argv.indexOf('--');
  if (dashIdx < 0) die('usage: claude-init exec [ENV_KEY=]<NAME>... -- <command> [args...]');
  const tokens = process.argv.slice(3, dashIdx);
  const cmd = process.argv.slice(dashIdx + 1);
  if (cmd.length === 0) die('no command after --');
  const { root } = ctx();
  const env = { ...process.env };
  for (const tok of tokens) {
    let envKey, secretName;
    if (tok.includes('=')) {
      const eq = tok.indexOf('=');
      envKey = tok.slice(0, eq);
      secretName = tok.slice(eq + 1);
    } else {
      envKey = tok;
      secretName = tok;
    }
    const r = secretsResolve.resolve(root, secretName);
    if (!r) die(`secret ${secretName} not found (project or user). Run: claude-init secret set ${secretName}`);
    try { env[envKey] = backends[r.ref.backend].get({ ref: r.ref }); }
    catch (err) { die(`failed to read ${secretName}: ${err.message}`); }
  }
  const r = spawnSync(cmd[0], cmd.slice(1), { stdio: 'inherit', env });
  process.exit(r.status ?? 1);
}

function helpText() {
  return `${bold('claude-init')} — per-project Claude Code setup

Usage:
  claude-init init          configure this repo
  claude-init check         first-run gate for a claude wrapper
  claude-init mcp ...       add, wrap, move, enable, or disable MCPs
  claude-init secret ...    list, set, get, or remove secrets
  claude-init plugin ...    enable or disable plugins per repo
  claude-init discover      print discovered MCPs and skills as JSON
  claude-init state         print this repo's override state as JSON

More help:
  claude-init help mcp
  claude-init help secret
  claude-init help plugin
  claude-init help wrapper
`;
}

function mcpHelpText() {
  return `${bold('claude-init mcp')} — manage MCP definitions and repo toggles

Usage:
  claude-init mcp add
      Add a new MCP server interactively.

  claude-init mcp wrap <name>
      Wrap an existing MCP in place for secret injection.

  claude-init mcp move [name] [--to user|project|local]
      Move an MCP definition between scopes.

  claude-init mcp remap [name]
      Point a wrapped env key at a different secret name.

  claude-init mcp enable <name>
  claude-init mcp disable <name>
      Toggle an MCP for this repo.

Scopes:
  user     ~/.claude.json mcpServers
  project  .mcp.json
  local    ~/.claude.json projects[repo].mcpServers
`;
}

function secretHelpText() {
  return `${bold('claude-init secret')} — manage secret references

Usage:
  claude-init secret list
      Show configured project and user secrets.

  claude-init secret set <NAME> [--scope user|project] [--backend keychain|op]
      Store or update a secret reference.

  claude-init secret get <NAME>
      Print the resolved secret value. Project scope wins over user scope.

  claude-init secret rm <NAME> [--scope user|project]
      Remove a secret reference and backend entry where supported.

Options for set:
  --scope user|project      Default: project
  --backend keychain|op     Default: keychain
  --ref op://...            1Password reference
  --isolate                 Use a repo-isolated Keychain service
  --value VALUE             Non-interactive Keychain value
`;
}

function pluginHelpText() {
  return `${bold('claude-init plugin')} — repo-level plugin overrides

Usage:
  claude-init plugin enable <id@market>
  claude-init plugin disable <id@market>
  claude-init plugin unset <id@market>
`;
}

function wrapperHelpText() {
  return `${bold('claude-init check')} — suggested claude wrapper

Add this to your shell rc if you alias Claude Code as cc:

  cc() {
    claude-init check || return
    claude "$@"
  }

The check command exits 0 when this repo is configured, skipped, or you choose "not now".
`;
}

async function main() {
  const argv = process.argv.slice(2);
  const sub = argv[0];
  const args = parseArgs(argv);
  if (sub === 'help') {
    const topic = argv[1];
    if (topic === 'mcp') process.stdout.write(mcpHelpText());
    else if (topic === 'secret') process.stdout.write(secretHelpText());
    else if (topic === 'plugin') process.stdout.write(pluginHelpText());
    else if (topic === 'wrapper' || topic === 'check') process.stdout.write(wrapperHelpText());
    else process.stdout.write(helpText());
    return;
  }
  switch (sub) {
    case 'init': return cmdInit(args);
    case 'check': return cmdCheck();
    case 'mcp': return cmdMcp(args);
    case 'plugin': return cmdPlugin(args);
    case 'discover': return cmdDiscover();
    case 'state': return cmdState();
    case 'secret': return cmdSecret(args);
    case 'exec': return cmdExec();
    case '--help':
    case '-h':
    case undefined:
      process.stdout.write(helpText());
      return;
    default: die(`unknown subcommand: ${sub}`);
  }
}

main().catch((err) => die(err.message || String(err)));
