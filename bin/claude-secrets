#!/usr/bin/env node
const fs = require('fs');
const path = require('path');
const { spawnSync } = require('child_process');
const readline = require('readline');

const libDir = path.resolve(__dirname, '..', 'lib');
const manifest = require(path.join(libDir, 'manifest'));
const discover = require(path.join(libDir, 'discover'));
const backends = {
  keychain: require(path.join(libDir, 'backends', 'keychain')),
  op: require(path.join(libDir, 'backends', 'op')),
};

function die(msg, code = 1) {
  process.stderr.write(`claude-secrets: ${msg}\n`);
  process.exit(code);
}

function parseArgs(argv) {
  const args = { _: [], flags: {} };
  for (let i = 0; i < argv.length; i++) {
    const a = argv[i];
    if (a === '--') { args._.push(...argv.slice(i + 1)); break; }
    if (a.startsWith('--')) {
      const [k, v] = a.slice(2).split('=');
      if (v !== undefined) args.flags[k] = v;
      else if (i + 1 < argv.length && !argv[i + 1].startsWith('--')) { args.flags[k] = argv[++i]; }
      else args.flags[k] = true;
    } else {
      args._.push(a);
    }
  }
  return args;
}

function readPasswordTty(prompt) {
  if (!process.stdin.isTTY) {
    return fs.readFileSync(0, 'utf8').replace(/\n$/, '');
  }
  process.stderr.write(prompt);
  const r = spawnSync('bash', ['-c', 'IFS= read -rs line && printf %s "$line"'], {
    stdio: ['inherit', 'pipe', 'inherit'],
  });
  process.stderr.write('\n');
  if (r.status !== 0) die('failed to read password');
  return r.stdout.toString();
}

function readLine(prompt) {
  return new Promise((resolve) => {
    const rl = readline.createInterface({ input: process.stdin, output: process.stderr });
    rl.question(prompt, (answer) => { rl.close(); resolve(answer); });
  });
}

function loadManifest() {
  const repoRoot = manifest.findRepoRoot();
  const data = manifest.read(repoRoot) || { version: 1, mcps: [], skills: [], secrets: {} };
  return { repoRoot, data };
}

function saveManifest(repoRoot, data) {
  manifest.write(repoRoot, data);
}

async function cmdDiscover() {
  const out = {
    mcps: discover.discoverMcps(),
    skills: discover.discoverSkills(),
  };
  process.stdout.write(JSON.stringify(out, null, 2) + '\n');
}

async function cmdSet(args) {
  const name = args._[1];
  if (!name) die('usage: claude-secrets set <NAME> [--backend keychain|op] [--ref op://...] [--isolate] [--value VAL]');
  const backend = args.flags.backend || 'keychain';
  if (!backends[backend]) die(`unknown backend: ${backend}`);

  const { repoRoot, data } = loadManifest();
  const isolated = !!args.flags.isolate;
  let ref;

  if (backend === 'keychain') {
    let value = args.flags.value;
    if (value === undefined || value === true) value = readPasswordTty(`Enter value for ${name}: `);
    if (!value) die('empty secret value');
    ref = backends.keychain.set({ name, value, isolated, repoHash: manifest.repoHash(repoRoot) });
  } else if (backend === 'op') {
    let opRef = args.flags.ref;
    if (!opRef || opRef === true) opRef = await readLine(`1Password reference for ${name} (op://...): `);
    ref = backends.op.set({ name, opRef });
  }

  data.secrets = data.secrets || {};
  data.secrets[name] = { ...ref, isolated: isolated || undefined };
  saveManifest(repoRoot, data);
  process.stdout.write(`stored ${name} (backend=${backend}${isolated ? ', isolated' : ''})\n`);
}

async function cmdGet(args) {
  const name = args._[1];
  if (!name) die('usage: claude-secrets get <NAME>');
  const { data } = loadManifest();
  const ref = (data.secrets || {})[name];
  if (!ref) die(`no secret named ${name} in manifest`);
  const value = backends[ref.backend].get({ ref });
  process.stdout.write(value);
}

async function cmdList() {
  const { data } = loadManifest();
  const secrets = data.secrets || {};
  const names = Object.keys(secrets);
  if (names.length === 0) { process.stdout.write('(no secrets)\n'); return; }
  for (const name of names) {
    const r = secrets[name];
    const detail = r.backend === 'keychain'
      ? `keychain (${r.service}${r.isolated ? ', isolated' : ''})`
      : `1password (${r.ref})`;
    process.stdout.write(`${name}\t${detail}\n`);
  }
}

async function cmdRm(args) {
  const name = args._[1];
  if (!name) die('usage: claude-secrets rm <NAME>');
  const { repoRoot, data } = loadManifest();
  const ref = (data.secrets || {})[name];
  if (!ref) die(`no secret named ${name}`);
  backends[ref.backend].rm({ ref });
  delete data.secrets[name];
  saveManifest(repoRoot, data);
  process.stdout.write(`removed ${name}\n`);
}

async function cmdExec() {
  const dashIdx = process.argv.indexOf('--');
  if (dashIdx < 0) die('usage: claude-secrets exec <NAME> [<NAME>...] -- <command> [args...]');
  const names = process.argv.slice(3, dashIdx);
  const cmd = process.argv.slice(dashIdx + 1);
  if (cmd.length === 0) die('no command after --');

  const { data } = loadManifest();
  const env = { ...process.env };
  for (const name of names) {
    const ref = (data.secrets || {})[name];
    if (!ref) die(`secret ${name} not found in manifest. Run: claude-secrets set ${name}`);
    try {
      env[name] = backends[ref.backend].get({ ref });
    } catch (err) {
      die(`failed to read ${name}: ${err.message}`);
    }
  }
  const r = spawnSync(cmd[0], cmd.slice(1), { stdio: 'inherit', env });
  process.exit(r.status ?? 1);
}

async function main() {
  const argv = process.argv.slice(2);
  const sub = argv[0];
  const args = parseArgs(argv);
  switch (sub) {
    case 'discover': return cmdDiscover();
    case 'set': return cmdSet(args);
    case 'get': return cmdGet(args);
    case 'list': return cmdList();
    case 'rm': return cmdRm(args);
    case 'exec': return cmdExec();
    case '--help':
    case '-h':
    case undefined:
      process.stdout.write(`claude-secrets — secret injection for Claude Code MCPs

usage:
  claude-secrets discover                           list available MCPs/skills
  claude-secrets set <NAME> [--backend keychain|op] store a secret reference
                  [--ref op://...] [--isolate]
                  [--value VAL]
  claude-secrets get <NAME>                         print secret to stdout
  claude-secrets list                               list secrets in current repo
  claude-secrets rm <NAME>                          remove a secret
  claude-secrets exec <NAME>... -- <cmd> [args]     run cmd with secrets in env
`);
      return;
    default: die(`unknown command: ${sub}`);
  }
}

main().catch((err) => die(err.message));
